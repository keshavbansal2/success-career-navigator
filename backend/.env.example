# Anthropic API Key (get yours at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# JWT Secret Key (use a long random string in production)
SECRET_KEY=your-secret-key-change-in-production

# JWT token expiry in minutes (default: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database URL (default: SQLite for local dev)
DATABASE_URL=sqlite:///./careernav.db
